	text-align: center;
	margin-bottom: 40rpx;
}

.page-title {
	font-size: 48rpx;
	font-weight: bold;
	color: #333333;
	display: block;
	margin-bottom: 20rpx;
}

.page-subtitle {
	font-size: 28rpx;
	color: #999999;
	display: block;
}

.template-grid {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 30rpx;
}

.template-card {
	background-color: #ffffff;
	border-radius: 20rpx;
	padding: 40rpx;
	box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
	display: flex;
	flex-direction: column;
	align-items: center;
	
	&:active {
		opacity: 0.8;
	}
}

.template-icon {
	font-size: 80rpx;
	margin-bottom: 20rpx;
}

.template-name {
	font-size: 32rpx;
	font-weight: bold;
	color: #333333;
	margin-bottom: 15rpx;
	text-align: center;
}

.template-desc {
	font-size: 24rpx;
	color: #666666;
	text-align: center;
	margin-bottom: 20rpx;
	line-height: 1.5;
}

.template-meta {
	display: flex;
	flex-direction: row;
	gap: 20rpx;
}

.meta-item {
	font-size: 22rpx;
	color: #999999;
	padding: 8rpx 16rpx;
	background-color: #f5f5f5;
	border-radius: 8rpx;
}

.loading-view {
	text-align: center;
	padding: 60rpx 0;
}

.loading-text {
	font-size: 28rpx;
	color: #999999;
}

.qa-process {
	background-color: #ffffff;
	border-radius: 20rpx;
	padding: 40rpx;
}

.progress-bar {
	width: 100%;
	height: 12rpx;
	background-color: #eeeeee;
	border-radius: 6rpx;
	overflow: hidden;
	margin-bottom: 20rpx;
}

.progress-fill {
	height: 100%;
	background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
	transition: width 0.3s;
}

.progress-text {
	text-align: center;
	margin-bottom: 40rpx;
	font-size: 28rpx;
	color: #666666;
}

.question-section {
	width: 100%;
}

.question-label {
	font-size: 32rpx;
	font-weight: bold;
	color: #333333;
	display: block;
	margin-bottom: 10rpx;
}

.question-required {
	font-size: 24rpx;
	color: #ff4d4f;
	display: block;
	margin-bottom: 30rpx;
}

.answer-input {
	width: 100%;
	min-height: 200rpx;
	padding: 20rpx;
	font-size: 28rpx;
	border: 2rpx solid #eeeeee;
	border-radius: 10rpx;
	background-color: #f8f8f8;
	margin-bottom: 40rpx;
}

.button-group {
	display: flex;
	flex-direction: row;
	gap: 20rpx;
}

.btn {
	flex: 1;
	height: 80rpx;
	font-size: 32rpx;
	border-radius: 10rpx;
	border: none;
}

.btn-primary {
	background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	color: #ffffff;
	font-weight: bold;
}

.btn-secondary {
	background-color: #f5f5f5;
	color: #666666;
}

.result-view {
	background-color: #ffffff;
	border-radius: 20rpx;
	padding: 80rpx 40rpx;
	text-align: center;
}

.success-icon {
	font-size: 120rpx;
	margin-bottom: 30rpx;
}

.success-title {
	font-size: 40rpx;
	font-weight: bold;
	color: #333333;
	display: block;
	margin-bottom: 20rpx;
}

.success-desc {
	font-size: 28rpx;
	color: #999999;
	display: block;
	margin-bottom: 60rpx;
}

.document-info {
	background-color: #f8f8f8;
	border-radius: 10rpx;
	padding: 30rpx;
	margin-bottom: 40rpx;
	text-align: left;
}

.info-item {
	font-size: 28rpx;
	color: #666666;
	display: block;
	margin-bottom: 15rpx;
	
	&:last-child {
		margin-bottom: 0;
	}
}
</style>
